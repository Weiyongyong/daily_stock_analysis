# ===================== AlphaSift 自动选股核心开关 =====================
# 开启自动选股引擎，True=启用，不再读取手动STOCK_LIST
ALPHASIFT_ENABLED=True
# 筛选后最多保留多少只股票进入AI深度分析
ALPHASIFT_TOP_N=5
# 选股市场 a=A股 hk=港股 us=美股 all=全部
ALPHASIFT_MARKET=a
# 启用的选股因子策略（按需删减）
# ma均线量价 / fund基本面 / money资金流向 / news舆情事件
ALPHASIFT_STRATEGIES=ma,volume,fund,money
# 因子权重（JSON字符串，不用修改默认即可）
ALPHASIFT_WEIGHTS={"tech":0.4,"fund":0.3,"money":0.2,"news":0.1}
# 过滤ST、退市、次新股开关
ALPHASIFT_FILTER_ST=True
ALPHASIFT_FILTER_NEW_STOCK=True
# 最小流通市值过滤（单位亿，过滤小盘垃圾股）
ALPHASIFT_MIN_MARKET_CAP=50
